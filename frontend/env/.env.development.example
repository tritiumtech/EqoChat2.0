# Development config. Copy to .env.development and adjust locally.
# Variables must use the VITE_ prefix to be exposed to client code.

NODE_ENV = development
VITE_ENV_STATUS = development

VITE_DELETE_CONSOLE = false
VITE_SHOW_SOURCEMAP = true

# Dev proxy/API/WebSocket placeholders
VITE_PROXY_TARGET = http://localhost:8080
VITE_API_BASE_URL = http://localhost:8080
VITE_WS_URL = ws://localhost:8080
