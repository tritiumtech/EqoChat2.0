# Common frontend config. Copy to .env and adjust locally.
# Variables must use the VITE_ prefix to be exposed to client code.

VITE_APP_TITLE = EqoChat
VITE_APP_PORT = 3000

# H5 deployment base path, e.g. /eqochat/
VITE_APP_PUBLIC_BASE = /

# Enable Vite dev proxy
VITE_APP_PROXY = true
VITE_APP_PROXY_PREFIX = /api

# Default language
VITE_FALLBACK_LOCALE = zh-CN
