# Production config. Copy to .env.production and set deployment endpoints.
# Variables must use the VITE_ prefix to be exposed to client code.

NODE_ENV = production
VITE_ENV_STATUS = production

VITE_DELETE_CONSOLE = true
VITE_SHOW_SOURCEMAP = false

VITE_PROXY_TARGET = https://api.example.com
VITE_API_BASE_URL = https://api.example.com
VITE_WS_URL = wss://api.example.com
